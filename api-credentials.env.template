# API Credentials for Podcast Outreach Automation
# DO NOT COMMIT THIS FILE TO GIT
# Copy this file to api-credentials.env and fill in your actual credentials

# ============================================================================
# SPOTIFY API CREDENTIALS
# ============================================================================
# Get these from: https://developer.spotify.com/dashboard
# See SPOTIFY_SETUP.md for detailed instructions

SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_LAWAYRA_SHOW_ID=your_spotify_show_id_here

# ============================================================================
# YOUTUBE DATA API CREDENTIALS
# ============================================================================
# Get this from: Google Cloud Console → APIs & Services → Credentials
# See YOUTUBE_SETUP.md for detailed instructions

YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_LAWAYRA_CHANNEL_ID=your_youtube_channel_id_here

# ============================================================================
# LISTEN NOTES API CREDENTIALS
# ============================================================================
# Get this from: https://www.listennotes.com/api/
# See LISTENNOTES_SETUP.md for detailed instructions
# Start with free tier (300 req/month), upgrade to paid later

LISTEN_NOTES_API_KEY=your_listen_notes_api_key_here
LISTEN_NOTES_TIER=free  # Options: free, basic ($49/mo), pro ($149/mo)

# ============================================================================
# AI API CREDENTIALS (Choose ONE)
# ============================================================================
# See AI_SETUP.md for detailed instructions

# Option 1: Anthropic Claude (Recommended for pitch generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option 2: OpenAI (Alternative)
OPENAI_API_KEY=your_openai_api_key_here

# Which AI provider to use in N8N workflows
AI_PROVIDER=anthropic  # Options: anthropic, openai

# ============================================================================
# GHL (GOHIGHLEVEL) API CREDENTIALS
# ============================================================================
# Get this from your GHL account settings
# See GHL_DRIP_SETUP.md for detailed instructions

GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here

# ============================================================================
# DRIP API CREDENTIALS
# ============================================================================
# Get this from your Drip account settings
# See GHL_DRIP_SETUP.md for detailed instructions

DRIP_API_KEY=your_drip_api_key_here
DRIP_ACCOUNT_ID=your_drip_account_id_here

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
# Email address to send outreach from

OUTREACH_FROM_EMAIL=sam@lawayra.com
OUTREACH_FROM_NAME=Sam from LaWayra

# ============================================================================
# GOOGLE SHEETS CONFIGURATION
# ============================================================================
# IDs of the Google Sheets you created
# Format: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit

GOOGLE_SHEET_GUEST_DATABASE_ID=your_guest_database_sheet_id_here
GOOGLE_SHEET_DISCOVERED_PODCASTS_ID=your_discovered_podcasts_sheet_id_here
GOOGLE_SHEET_ANALYTICS_DASHBOARD_ID=your_analytics_dashboard_sheet_id_here

# ============================================================================
# WORKFLOW CONFIGURATION
# ============================================================================

# Daily outreach limits (start low, scale up)
DAILY_EMAIL_LIMIT=10  # Week 1: 5-10, Week 2: 10-15, Week 3+: 20-30

# Rate limiting (minutes between emails)
EMAIL_SEND_DELAY_MINUTES=3

# Follow-up timing (days)
FOLLOWUP_DELAY_DAYS=5
FINAL_FOLLOWUP_DELAY_DAYS=7

# Batch sizes for processing
PODCAST_DISCOVERY_BATCH_SIZE=20
ENRICHMENT_BATCH_SIZE=20

# ============================================================================
# SETUP COMPLETION CHECKLIST
# ============================================================================
# Mark each as DONE when completed:
# [ ] Spotify API credentials obtained
# [ ] YouTube API credentials obtained
# [ ] Listen Notes API credentials obtained
# [ ] AI API credentials obtained (Claude or OpenAI)
# [ ] GHL API credentials obtained
# [ ] Drip API credentials obtained
# [ ] Google Sheets created and IDs added above
# [ ] All credentials tested in N8N
